# ---------------------------------------------------------------------------
# ADE – Agentic Document Extraction
# Environment configuration
#
# No paid API keys required.  All LLM inference runs locally via Ollama.
# Install Ollama from https://ollama.com and pull a model, e.g.:
#   ollama pull llama3.2
#   ollama pull mistral
# ---------------------------------------------------------------------------

# Ollama server (default: localhost)
OLLAMA_BASE_URL=http://localhost:11434/v1

# Primary model (used for classification, schema-building, extraction)
OLLAMA_MODEL=llama3.2

# Secondary / "llama-choice" model alias
OLLAMA_MODEL_ALT=mistral

# Local embedding model (SentenceTransformers)
# Options: all-MiniLM-L6-v2 (fast, 384-dim) | all-mpnet-base-v2 (better, 768-dim)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ---------------------------------------------------------------------------
# Optional: LangSmith tracing (leave empty to disable)
# ---------------------------------------------------------------------------
LANGCHAIN_API_KEY=
