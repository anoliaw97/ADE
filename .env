# ---------------------------------------------------------------------------
# ADE – Agentic Document Extraction  |  Environment Variables
# ---------------------------------------------------------------------------
# Copy this file to .env and fill in your keys.
# NEVER commit .env to git — it is already listed in .gitignore.

# ── Required: OpenAI (GPT-4o-mini + text-embedding-ada-002) ────────────────
OPENAI_API_KEY=your-openai-api-key-here

# ── Required for --llm-choice llama: Groq (free Llama inference) ───────────
# Get a free key at https://console.groq.com
# Free models available: llama-3.3-70b-versatile, llama3-8b-8192,
#                        mixtral-8x7b-32768, gemma2-9b-it
GROQ_API_KEY=your-groq-api-key-here

# ── Optional: LangSmith tracing (observability only — NOT required) ─────────
# The LangChain framework itself is free and needs no key.
# LangSmith is only for viewing traces at https://smith.langchain.com
# Leave blank or remove this line entirely to disable tracing.
LANGCHAIN_API_KEY=
