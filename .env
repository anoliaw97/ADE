# ADE — Local VLM + LLM branch
# No API keys required — all inference runs on-device via HuggingFace.
#
# Models used:
#   VLM : allenai/olmOCR-2-7B-1025  (PDF OCR, optional --use-vlm flag)
#   LLM : Qwen/Qwen2.5-3B-Instruct  (classification, schema building, extraction)
#
# The variables below are kept as placeholders in case you want to
# switch back to an API-based branch.  They are NOT read by this branch.

OPENAI_API_KEY=
TOGETHER_API_KEY=
LANGCHAIN_API_KEY=
